{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "the-undervault",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "user"
    }
  },
  "menu": {
    "items": [
      {
        "label": "Undervault: mint today's descent",
        "description": "Creates the daily post (manual reshuffle)",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mint-day"
      }
    ]
  },
  "scheduler": {
    "tasks": {
      "reshuffle": {
        "endpoint": "/internal/jobs/reshuffle",
        "cron": "0 0 * * *"
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build -c vite.devvit.config.ts",
    "dev": "vite build --watch -c vite.devvit.config.ts"
  }
}